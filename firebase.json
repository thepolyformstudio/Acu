{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "site": "acudex",
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/privacy",
        "destination": "/privacy.html"
      },
      {
        "source": "/tutorials",
        "destination": "/tutorials.html"
      },
      {
        "source": "/api/**",
        "run": {
          "serviceId": "ssracudex",
          "region": "us-central1"
        }
      }
    ]
  }
}
