rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles: own doc only
    match /profiles/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
                    && request.resource.data.id == uid;
      allow create: if request.auth != null && request.auth.uid == uid
                     && request.resource.data.id == uid;

      // User's documents
      match /documents/{docId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // User's exam attempts
      match /attempts/{attemptId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // User's study artifacts
      match /artifacts/{artifactId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Child profiles: parent can read/write their children
    match /children/{childId} {
      allow read, write: if request.auth != null
        && request.auth.uid == get(/databases/$(database)/documents/children/$(childId)).data.parentId;
      allow create: if request.auth != null
        && request.resource.data.parentId == request.auth.uid;
    }

    // Reviews: public read, authenticated write with rate limiting
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete, update: if request.auth != null
        && request.auth.uid == get(/databases/$(database)/documents/reviews/$(reviewId)).data.userId;
    }

    // Coupons: admin only via cloud function
    match /coupons/{code} {
      allow read, write: if false;
    }
  }
}
